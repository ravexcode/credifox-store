generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String        @id @default(uuid())
  name          String
  type          String
  variations    String[]
  cost          Int
  values        Json
  images_url    String[]
}

model User {
  id            String        @id @default(uuid())
  tag           String        @unique
  uploaded      Json[]
  name          String
  password      String
  logged_at     DateTime?
  created_at    DateTime      @default(now())
}